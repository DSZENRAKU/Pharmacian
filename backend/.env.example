# Example environment variables for Pharmacian backend
FLASK_ENV=production
FLASK_APP=backend.flask_app_init:create_app
SECRET_KEY=change_me_to_a_secure_random_value
MODEL_DIR=./models
MODEL_VERSION=1.0.0
BACKUP_ENCRYPTION_KEY=replace-with-secure-key
DATABASE_URL=sqlite:///./data/clinical.db
LOG_LEVEL=INFO
